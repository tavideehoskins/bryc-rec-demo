;; shadow-cljs configuration
{:deps {:aliases [:dev :test]}

 ;; push-state/index serves index.html for client-side routes (e.g. /rec-demo)
 ;; on direct load + refresh, so the SPA router can take over.
 :dev-http {8080 {:root "public" :push-state/index "index.html"}}

 :builds
 {:test
  {:target :node-test
   :output-to "out/test/node-tests.js"
   :ns-regexp "-test$"
   :autorun true}

  :app
  {:target :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules {:main {:entries [app.core]
                    :init-fn app.core/init}}
   :devtools {:preloads [uix.preload devtools.preload]}
   :dev {:compiler-options {:source-map true
                           :optimizations :none}}
   :release {:compiler-options {:optimizations :advanced
                               :source-map false
                               :elide-asserts true
                               :pretty-print false}}
   :js-options {:js-package-dirs    ["node_modules" "src/gen"]
                ;; Use :es-unsupported to bypass Closure Compiler parsing of modern JS
                ;; features like private class properties (#field) in Radix UI dependencies
                :output-feature-set :es-unsupported
                :language-in        :unsupported
                :js-options {:resolve {"gen" "dist/gen"}}}}

  ;; Standalone PROTOTYPE build for public hosting (GitHub Pages). Bundles ONLY
  ;; the rec-demo page — no router/API/other app code. Relative :asset-path so it
  ;; works under a project-pages subpath (user.github.io/<repo>/). :simple opts
  ;; avoid advanced-compilation name-munging issues with recharts/radix.
  :rec-demo
  {:target :browser
   :output-dir "rec-demo-site/js"
   :asset-path "js"
   :modules {:main {:entries [rec-demo.standalone]
                    :init-fn rec-demo.standalone/init}}
   :release {:compiler-options {:optimizations :simple
                               :source-map false
                               :pretty-print false}}
   :js-options {:js-package-dirs    ["node_modules" "src/gen"]
                :output-feature-set :es-unsupported
                :language-in        :unsupported
                :js-options {:resolve {"gen" "dist/gen"}}}}}}
