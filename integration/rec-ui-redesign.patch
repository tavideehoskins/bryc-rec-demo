+;; ----------------------------------------------------------------------------
+;; Expected Outcomes — stat grid (LWC, SOC 29-1141 Registered Nurses)
+;; ----------------------------------------------------------------------------
+
+(def expected-outcomes-stats
+  [{:label "Louisiana Median Wage"        :value "$76,636"  :sub "per year"}
+   {:label "Starting Range (lowest 10%)"  :value "$60,722"  :sub "per year"}
